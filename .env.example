# Copy this file to .env and set MY_BOARD for your target.

# Adafruit QT Py ESP32-S3 (joystick_controller)
MY_BOARD=adafruit_qt_py_esp32s3/esp32s3/procpu

# Robotis OpenRB-150 (motor_controller)
# MY_BOARD=robotis_openrb_150

# Raspberry Pi Pico (pico_fw)
# MY_BOARD=rpi_pico/rp2040

# nRF5340 DK (bluetooth_proxy_device)
# MY_BOARD=nrf5340dk/nrf5340/cpuapp

# QEMU for local testing
# MY_BOARD=qemu_cortex_m3
