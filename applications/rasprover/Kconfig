mainmenu "Application options"

# Workaround for an upstream regression: mcumgr's img_mgmt.c references
# CONFIG_FLASH_BASE_ADDRESS, but arch/Kconfig only defines that symbol for
# ARC/ARM/ARM64/X86/RISCV/RX/OPENRISC/ARCH_POSIX — not Xtensa. ESP32 flash
# partition addresses are zero-based offsets, so 0 is the correct base.
# Remove once deps/zephyr carries the upstream fix.
config FLASH_BASE_ADDRESS
	hex
	depends on XTENSA
	default 0

if DNS_RESOLVER

config DNS_SERVER_IP_ADDRESSES
	default y

config DNS_SERVER1
	default "1.1.1.1"

endif # DNS_RESOLVER

menuconfig APP_DISPLAY
	bool "Enable App Display"
	select DISPLAY
	select LVGL
	# select LV_CONF_MINIMAL

if APP_DISPLAY

config APP_DISPLAY_BLANK_ON_IDLE
	bool "Blank display on idle"
#	default y if SSD1306

choice APP_DISPLAY_WORK_QUEUE
	prompt "Work queue selection for UI updates"

config APP_DISPLAY_WORK_QUEUE_SYSTEM
	bool "Use default system work queue for UI updates"

config APP_DISPLAY_WORK_QUEUE_DEDICATED
	bool "Use dedicated work queue for UI updates"

endchoice

if APP_DISPLAY_WORK_QUEUE_DEDICATED

config APP_DISPLAY_DEDICATED_THREAD_STACK_SIZE
	int "Stack size for dedicated UI thread/queue"
	default 2048

config APP_DISPLAY_DEDICATED_THREAD_PRIORITY
	int "Thread priority for dedicated UI thread/queue"
	default 5

endif # APP_DISPLAY_WORK_QUEUE_DEDICATED

endif # APP_DISPLAY

menuconfig APP_ZENOH
	bool "Enable zenoh-pico publisher"
	select ZENOH_PICO
	select ZENOH_PICO_LINK_TCP
	select ZENOH_PICO_PUBLICATION
	select ZENOH_PICO_MULTI_THREAD
	default y

if APP_ZENOH

config APP_ZENOH_LOCATOR
	string "Zenoh locator for the host router"
	default "tcp/192.168.1.10:7447"
	help
	  Locator string passed to z_open() as the connect endpoint. Format is
	  '<protocol>/<host>:<port>'. The host typically runs zenohd configured
	  with a matching listen endpoint, e.g. `zenohd -l tcp/0.0.0.0:7447`.

config APP_ZENOH_KEY_PREFIX
	string "Zenoh key expression prefix for all published topics"
	default "rt/rasprover"
	help
	  Key prefix for all zenoh publishers. The 'rt/' convention is required
	  by the zenoh-ros2dds bridge to route topics into ROS2. The full key
	  for the battery state topic will be <prefix>/battery_state, which
	  maps to the ROS2 topic /<prefix_without_rt>/battery_state.

# Numeric tunables consumed by the generated zenoh-pico/config.h (see
# poe.toml: patch-zenoh). Defaults match the upstream zenoh-pico root
# CMakeLists.txt so behaviour matches a stock build.
config APP_ZENOH_FRAG_MAX_SIZE
	int "Zenoh: maximum size for fragmented messages (bytes)"
	default 4096

config APP_ZENOH_BATCH_UNICAST_SIZE
	int "Zenoh: maximum unicast batch size (bytes)"
	default 2048

config APP_ZENOH_BATCH_MULTICAST_SIZE
	int "Zenoh: maximum multicast batch size (bytes)"
	default 2048

config APP_ZENOH_SOCKET_TIMEOUT_MS
	int "Zenoh: default socket timeout (ms)"
	default 100

config APP_ZENOH_TRANSPORT_LEASE_MS
	int "Zenoh: link lease duration announced to peers (ms)"
	default 10000

config APP_ZENOH_TRANSPORT_LEASE_EXPIRE_FACTOR
	int "Zenoh: session lease expire factor"
	default 3

config APP_ZENOH_RUNTIME_MAX_TASKS
	int "Zenoh: maximum number of runtime tasks"
	default 64

config APP_ZENOH_TRANSPORT_ACCEPT_TIMEOUT_MS
	int "Zenoh: P2P link accept timeout (ms)"
	default 1000

config APP_ZENOH_TRANSPORT_CONNECT_TIMEOUT_MS
	int "Zenoh: P2P link connect timeout (ms)"
	default 10000

endif # APP_ZENOH

menuconfig APP_MOTORS
	bool "Enable differential drive motor control"
	default y
	depends on ACTUATOR
	help
	  Drives the two h-bridge wheel motors from cmd_vel twist commands
	  with open-loop duty mixing and a stop-on-silence watchdog.

if APP_MOTORS

config APP_MOTORS_WHEEL_SEPARATION_MM
	int "Wheel separation (track width) in mm"
	default 125
	help
	  Distance between the left and right wheel contact points.
	  Vendor value for the Waveshare RaspRover is 125 mm.

config APP_MOTORS_MAX_SPEED_MM_S
	int "Wheel speed mapped to 100% duty, in mm/s"
	default 500
	help
	  Open-loop scaling: a commanded wheel speed of this magnitude
	  produces full PWM duty. Tune on hardware.

config APP_MOTORS_CMD_TIMEOUT_MS
	int "Stop motors after this many ms without a cmd_vel"
	default 500

endif # APP_MOTORS

source "Kconfig.zephyr"
